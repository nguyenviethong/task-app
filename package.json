{
  "name": "task-manager",
  "version": "1.0.6",
  "description": "",
  "main": "main/main.js",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "build": "vite build",
    "dist": "vite build && electron-builder --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.3",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "electron-rebuild": "^3.2.9",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.7.3",
    "fuse.js": "^7.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "react": "^19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-calendar-heatmap": "^1.10.0",
    "react-chartjs-2": "^5.3.1",
    "react-confetti": "^6.4.0",
    "react-date-range": "^2.0.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-window": "^2.2.6",
    "recharts": "^3.7.0"
  },
  "build": {
    "appId": "com.todo.app",
    "extraResources": [
      {
        "from": "public.pem",
        "to": "public.pem"
      }
    ],
    "productName": "Task Manager By ITHONG",
    "publish": [
      {
        "provider": "github",
        "owner": "nguyenviethong",
        "repo": "task-app"
      }
    ],
    "icon": "assets/icon",
    "files": [
      "dist/**/*",
      "main/**/*",
      "preload.js"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
